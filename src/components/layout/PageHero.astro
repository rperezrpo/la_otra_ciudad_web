---
// PageHero — shared header for all inner pages.
// Pass `image` with a path from /public/images/banners/ to use a photo background.
// If no image is provided, falls back to the warm dark gradient.
//
// Usage:
//   <PageHero eyebrow="Quiénes Somos" image="/images/banners/quienes-somos.jpg">
//     <h1 class="page-hero-title">...</h1>
//     <p class="page-hero-sub">...</p>
//   </PageHero>

interface Props {
  eyebrow?: string;
  image?: string;
}

const { eyebrow, image } = Astro.props;

const bgStyle = image
  ? `background-image: linear-gradient(135deg, rgba(26,20,16,0.78) 0%, rgba(42,26,10,0.68) 55%, rgba(59,26,26,0.58) 100%), url('${image}'); background-size: cover; background-position: center;`
  : `background: linear-gradient(135deg, #1a1410 0%, #2a1a0a 60%, #3b1a1a 100%);`;
---

<div class="page-hero" style={bgStyle}>
  {eyebrow && <span class="eyebrow-light">{eyebrow}</span>}
  <slot />
</div>
