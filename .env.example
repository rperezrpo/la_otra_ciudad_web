# Sanity — exposed to the client (Studio + build queries). Safe to be public.
PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production

# Sanity — server-side only. Used by the one-off content import script.
# Create at https://www.sanity.io/manage → API → Tokens (Editor permission).
# NEVER commit this value.
SANITY_WRITE_TOKEN=your_write_token
